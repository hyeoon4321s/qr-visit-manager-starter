# Supabase 프로젝트 주소입니다.
SUPABASE_URL=https://your-project.supabase.co

# 공개용 Publishable key입니다. 방문 기록 함수 호출에만 사용합니다.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# 서버 전용 Secret key입니다. 브라우저 코드나 GitHub에 절대 공개하지 마세요.
SUPABASE_SECRET_KEY=sb_secret_your_key

# 기존 프로젝트라면 위 Secret key 대신 legacy service_role 키도 사용할 수 있습니다.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# 로컬에서는 아래 값을 사용하고, Vercel에서는 실제 배포 주소로 바꿉니다.
PUBLIC_BASE_URL=http://localhost:3000

# QR 생성과 통계 화면을 보호하는 학습용 관리자 키입니다.
ADMIN_API_KEY=길고_임의적인_문자열로_바꾸세요

PORT=3000
